<section class="auth-page">
  <div class="auth-card">

    <h1>Forgot Password</h1>
    <p>Enter your email and we'll generate a reset link for you.</p>

    {{#if error}}
    <div class="auth-error" role="alert">
      <span class="auth-error-icon" aria-hidden="true">!</span>
      <span>{{error}}</span>
    </div>
    {{/if}}

    {{#if message}}
    <div class="auth-success" role="status" style="background:#e6f4ea; border:1px solid #a8d5b5; border-radius:6px; padding:12px 16px; margin-bottom:16px; color:#2d6a3f;">
      <p style="margin:0 0 8px;">{{message}}</p>
      <a href="{{resetLink}}" style="word-break:break-all;">{{resetLink}}</a>
    </div>
    {{/if}}

    <form class="auth-form" method="POST" action="/forgot-password" novalidate>
      <div class="form-field">
        <label class="form-label" for="forgot-email">Email Address</label>
        <input
          class="form-input"
          type="email"
          id="forgot-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        >
      </div>

      <button type="submit" class="auth-submit">Generate Reset Link</button>
    </form>

    <p class="auth-switch">
      Remembered your password? <a href="/login">Sign in</a>
    </p>

  </div>
</section>
