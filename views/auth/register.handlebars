<section class="auth-page">
  <div class="auth-card">

    <h1>Create Account</h1>
    <p>Join NYC Roots &amp; Flavors to follow cultures and save favorites.</p>

    {{#if error}}
    <div class="auth-error" role="alert">
      <span class="auth-error-icon" aria-hidden="true">!</span>
      <span>{{error}}</span>
    </div>
    {{/if}}

    <form class="auth-form" id="register-form" method="POST" action="/register" novalidate>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
        <div class="form-field">
          <label class="form-label" for="reg-first">First Name</label>
          <input
            class="form-input"
            type="text"
            id="reg-first"
            name="firstName"
            placeholder="Jane"
            autocomplete="given-name"
            required
          >
        </div>
        <div class="form-field">
          <label class="form-label" for="reg-last">Last Name</label>
          <input
            class="form-input"
            type="text"
            id="reg-last"
            name="lastName"
            placeholder="Doe"
            autocomplete="family-name"
            required
          >
        </div>
      </div>

      <div class="form-field">
        <label class="form-label" for="reg-email">Email Address</label>
        <input
          class="form-input"
          type="email"
          id="reg-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        >
      </div>

      <div class="form-field">
        <label class="form-label" for="reg-password">Password</label>
        <input
          class="form-input"
          type="password"
          id="reg-password"
          name="password"
          placeholder="Create a strong password"
          autocomplete="new-password"
          required
        >
      </div>

      <button type="submit" class="auth-submit">Create Account</button>
    </form>

    <p class="auth-switch">
      Already have an account? <a href="/login">Sign in</a>
    </p>

  </div>
</section>
<script src="/public/js/auth.js" defer></script>
