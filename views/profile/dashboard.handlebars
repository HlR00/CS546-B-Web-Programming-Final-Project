<section class="auth-page">

<div class="auth-card">

<h1>
Welcome {{user.firstName}}
</h1>

<p>
Role: {{user.role}}
</p>

<hr>

<h3>Followed Cultures</h3>

<ul>
{{#each user.followedCultures}}
<li>{{this}}</li>
{{/each}}
</ul>

<form method="POST" action="/culture/add">

<input
name="culture"
placeholder="Add Culture"
required
>

<button class="btn-primary">
Add Culture
</button>

</form>

<form method="POST" action="/culture/remove">

<input
name="culture"
placeholder="Remove Culture"
required
>

<button class="btn-primary">
Remove Culture
</button>

</form>

<hr>

<h3>Must Buy List</h3>

<ul>
{{#each user.mustBuyList}}
<li>{{this}}</li>
{{/each}}
</ul>

<form method="POST" action="/mustbuy/add">

<input
name="item"
placeholder="Add Item"
required
>

<button class="btn-primary">
Add Item
</button>

</form>

<form method="POST" action="/mustbuy/remove">

<input
name="item"
placeholder="Remove Item"
required
>

<button class="btn-primary">
Remove Item
</button>

</form>

<hr>

<a href="/map">Map</a> |
<a href="/seasonal">Seasonal</a> |
<a href="/logout">Logout</a>

</div>

</section>